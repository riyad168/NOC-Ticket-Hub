<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="row g-3">
    <% if (user && user.role === 'admin') { %>
    <div class="col-lg-4">
      <div class="card">
        <div class="card-body p-4">
          <h6 class="fw-600 mb-3" style="font-size:14px;"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Category</h6>
          <% if (error) { %>
          <div class="alert alert-danger py-2" style="font-size:13px;"><%= error %></div>
          <% } %>
          <form method="POST" action="/categories/create">
            <div class="mb-3">
              <label class="form-label fw-600" style="font-size:13px;">Category Name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" required placeholder="e.g. Link Down" />
            </div>
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus me-1"></i>Add Category</button>
          </form>
        </div>
      </div>
    </div>
    <% } %>
    <div class="col-lg-<%= user && user.role === 'admin' ? '8' : '12' %>">
      <div class="card">
        <div class="card-body">
          <h6 class="fw-600 mb-3" style="font-size:14px;"><i class="bi bi-tags me-2 text-primary"></i>All Categories (<%= categories.length %>)</h6>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Category Name</th>
                  <th>Total Tickets</th>
                  <th>Created</th>
                  <% if (user && user.role === 'admin') { %><th>Action</th><% } %>
                </tr>
              </thead>
              <tbody>
                <% if (categories.length === 0) { %>
                <tr><td colspan="5" class="text-center text-muted py-4">No categories found</td></tr>
                <% } %>
                <% categories.forEach((cat, i) => { %>
                <tr>
                  <td style="color:#94a3b8;font-size:13px;"><%= i + 1 %></td>
                  <td style="font-weight:600;font-size:13.5px;"><%= cat.name %></td>
                  <td><span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:12px;"><%= cat._count.tickets %></span></td>
                  <td style="font-size:12px;color:#94a3b8;"><%= new Date(cat.createdAt).toLocaleDateString() %></td>
                  <% if (user && user.role === 'admin') { %>
                  <td>
                    <% if (cat._count.tickets === 0) { %>
                    <form method="POST" action="/categories/<%= cat.id %>/delete" onsubmit="return confirm('Delete category?')">
                      <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                    </form>
                    <% } else { %>
                    <span class="text-muted" style="font-size:12px;"><i class="bi bi-lock me-1"></i>In use</span>
                    <% } %>
                  </td>
                  <% } %>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
