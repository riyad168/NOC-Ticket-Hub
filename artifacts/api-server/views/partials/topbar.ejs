<div id="topbar">
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-sm btn-light d-md-none" id="sidebarToggle">
      <i class="bi bi-list fs-5"></i>
    </button>
    <span class="page-title"><%= title %></span>
  </div>
  <div class="d-flex align-items-center gap-3">
    <% if (user) { %>
    <div class="d-flex align-items-center gap-2">
      <div style="width:34px;height:34px;background:#3b82f6;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:13px;">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>
      <div class="d-none d-md-block">
        <div style="font-size:13px;font-weight:600;color:#0f172a;line-height:1.2;"><%= user.name %></div>
        <div style="font-size:11px;color:#64748b;"><%= user.role.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></div>
      </div>
    </div>
    <% } %>
  </div>
</div>
<script>
  document.getElementById('sidebarToggle')?.addEventListener('click', () => {
    document.getElementById('sidebar')?.classList.toggle('show');
  });
</script>
