<div id="topbar">
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-sm btn-light d-md-none" id="sidebarToggle">
      <i class="bi bi-list fs-5"></i>
    </button>
    <span class="page-title">NOC Ticket Management System</span>
  </div>
  <div class="d-flex align-items-center gap-3">
    <!-- Notification Bell -->
    <div class="position-relative" style="cursor:pointer;">
      <i class="bi bi-bell" style="font-size:20px;color:#64748b;"></i>
      <span style="position:absolute;top:-4px;right:-4px;width:16px;height:16px;background:#ef4444;border-radius:50%;font-size:10px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;">1</span>
    </div>
    <!-- Telegram -->
    <div style="cursor:pointer;" title="Telegram Notifications">
      <i class="bi bi-telegram" style="font-size:20px;color:#229ED9;"></i>
    </div>
    <!-- User -->
    <% if (user) { %>
    <div class="d-flex align-items-center gap-2">
      <div style="width:36px;height:36px;background:#3b82f6;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:14px;">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>
      <div class="d-none d-md-block">
        <div style="font-size:13px;font-weight:600;color:#0f172a;line-height:1.2;"><%= user.name %></div>
        <div style="font-size:11px;color:#64748b;"><%= user.role === 'noc_engineer' ? 'Engineer' : user.role.charAt(0).toUpperCase() + user.role.slice(1) %></div>
      </div>
    </div>
    <% } %>
  </div>
</div>
<script>
  document.getElementById('sidebarToggle')?.addEventListener('click', () => {
    document.getElementById('sidebar')?.classList.toggle('show');
  });
</script>
