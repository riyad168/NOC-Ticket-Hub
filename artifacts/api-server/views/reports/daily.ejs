<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <!-- Date Selector -->
  <div class="card mb-4">
    <div class="card-body py-3">
      <form method="GET" class="d-flex align-items-end gap-3">
        <div>
          <label class="form-label mb-1" style="font-size:12px;font-weight:600;color:#64748b;">SELECT DATE</label>
          <input type="date" name="date" class="form-control form-control-sm" value="<%= date %>" />
        </div>
        <button type="submit" class="btn btn-primary btn-sm px-4"><i class="bi bi-search me-1"></i>Generate</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
      </form>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count"><%= stats.total %></div>
        <div class="label">Total</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count text-warning"><%= stats.open %></div>
        <div class="label">Open</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count" style="color:#f59e0b;"><%= stats.inProgress %></div>
        <div class="label">In Progress</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count text-success"><%= stats.resolved %></div>
        <div class="label">Resolved</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count text-secondary"><%= stats.closed %></div>
        <div class="label">Closed</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card text-center">
        <div class="count text-danger"><%= stats.slaBreached %></div>
        <div class="label">SLA Breach</div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-600" style="font-size:14px;"><i class="bi bi-calendar-day me-2 text-primary"></i>Daily Report — <%= new Date(date).toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></h6>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr><th>Ticket No</th><th>Customer</th><th>Category</th><th>Status</th><th>Engineer</th><th>Created</th><th>SLA</th></tr>
          </thead>
          <tbody>
            <% if (tickets.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-2 d-block mb-2"></i>No tickets on this date</td></tr>
            <% } %>
            <% tickets.forEach(t => { %>
            <tr>
              <td><a href="/tickets/<%= t.id %>" class="fw-600 text-primary text-decoration-none"><%= t.ticketNumber %></a></td>
              <td><%= t.customer.name %></td>
              <td><span class="badge bg-light text-secondary" style="font-size:11px;"><%= t.category.name %></span></td>
              <td><span class="badge-status badge-<%= t.status.toLowerCase().replace('_','_') %>"><%= t.status.replace('_',' ') %></span></td>
              <td style="font-size:13px;"><%= t.assignedEngineer ? t.assignedEngineer.name : '—' %></td>
              <td style="font-size:12px;color:#64748b;"><%= new Date(t.createdAt).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %></td>
              <td><% if(t.slaBreached){%><span class="badge-status badge-sla">Breach</span><%}else{%><span class="badge-status badge-within">OK</span><%}%></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
