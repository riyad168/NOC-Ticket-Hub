<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="card mb-4">
    <div class="card-body py-3">
      <form method="GET" class="d-flex align-items-end gap-3 flex-wrap">
        <div>
          <label class="form-label mb-1" style="font-size:12px;font-weight:600;color:#64748b;">YEAR</label>
          <select name="year" class="form-select form-select-sm" style="width:120px;">
            <% for(let y = new Date().getFullYear(); y >= 2023; y--) { %>
            <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
            <% } %>
          </select>
        </div>
        <div>
          <label class="form-label mb-1" style="font-size:12px;font-weight:600;color:#64748b;">MONTH</label>
          <select name="month" class="form-select form-select-sm" style="width:140px;">
            <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((m, idx) => { %>
            <option value="<%= idx + 1 %>" <%= (idx + 1) === month ? 'selected' : '' %>><%= m %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm px-4"><i class="bi bi-search me-1"></i>Generate</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
      </form>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count"><%= stats.total %></div><div class="label">Total</div></div></div>
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count text-warning"><%= stats.open %></div><div class="label">Open</div></div></div>
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count" style="color:#f59e0b;"><%= stats.inProgress %></div><div class="label">In Progress</div></div></div>
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count text-success"><%= stats.resolved %></div><div class="label">Resolved</div></div></div>
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count text-secondary"><%= stats.closed %></div><div class="label">Closed</div></div></div>
    <div class="col-6 col-md-2"><div class="stat-card text-center"><div class="count text-danger"><%= stats.slaBreached %></div><div class="label">SLA Breach</div></div></div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-5">
      <div class="card">
        <div class="card-body">
          <h6 class="fw-600 mb-3" style="font-size:14px;">Breakdown by Category</h6>
          <% Object.entries(categoryBreakdown).forEach(([name, count]) => { %>
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span style="font-size:13px;"><%= name %></span>
            <span class="badge bg-primary bg-opacity-10 text-primary"><%= count %></span>
          </div>
          <div class="progress mb-2" style="height:6px;">
            <div class="progress-bar bg-primary" style="width:<%= stats.total > 0 ? Math.round(count/stats.total*100) : 0 %>%"></div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="col-md-7">
      <div class="card h-100">
        <div class="card-body">
          <h6 class="fw-600 mb-3" style="font-size:14px;">Category Distribution</h6>
          <canvas id="catChart" height="200"></canvas>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h6 class="fw-600 mb-3" style="font-size:14px;"><i class="bi bi-calendar-month me-2 text-primary"></i>Monthly Report — <%= ['January','February','March','April','May','June','July','August','September','October','November','December'][month-1] %> <%= year %></h6>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead><tr><th>Ticket No</th><th>Customer</th><th>Category</th><th>Status</th><th>Engineer</th><th>Date</th><th>SLA</th></tr></thead>
          <tbody>
            <% if (tickets.length === 0) { %><tr><td colspan="7" class="text-center text-muted py-4">No tickets this month</td></tr><% } %>
            <% tickets.forEach(t => { %>
            <tr>
              <td><a href="/tickets/<%= t.id %>" class="fw-600 text-primary text-decoration-none"><%= t.ticketNumber %></a></td>
              <td><%= t.customer.name %></td>
              <td><span class="badge bg-light text-secondary" style="font-size:11px;"><%= t.category.name %></span></td>
              <td><span class="badge-status badge-<%= t.status.toLowerCase().replace('_','_') %>"><%= t.status.replace('_',' ') %></span></td>
              <td style="font-size:13px;"><%= t.assignedEngineer ? t.assignedEngineer.name : '—' %></td>
              <td style="font-size:12px;color:#64748b;"><%= new Date(t.createdAt).toLocaleDateString() %></td>
              <td><% if(t.slaBreached){%><span class="badge-status badge-sla">Breach</span><%}else{%><span class="badge-status badge-within">OK</span><%}%></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
<script>
const catBreakdown = <%- JSON.stringify(categoryBreakdown) %>;
const labels = Object.keys(catBreakdown);
if (labels.length) {
  new Chart(document.getElementById('catChart').getContext('2d'), {
    type: 'bar',
    data: { labels, datasets: [{ label: 'Tickets', data: Object.values(catBreakdown), backgroundColor: '#3b82f6', borderRadius: 6 }] },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
  });
}
</script>
