<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="row g-3 mb-4">
    <% data.forEach(d => { %>
    <div class="col-md-6 col-xl-4">
      <div class="card">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:44px;height:44px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#3b82f6;font-size:16px;flex-shrink:0;">
              <%= d.engineer.name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <div style="font-size:14px;font-weight:700;color:#0f172a;"><%= d.engineer.name %></div>
              <div style="font-size:12px;color:#64748b;"><%= d.engineer.email %></div>
            </div>
          </div>
          <div class="row g-2 text-center">
            <div class="col-4">
              <div style="background:#f8fafc;border-radius:10px;padding:10px 6px;">
                <div style="font-size:20px;font-weight:700;color:#0f172a;"><%= d.total %></div>
                <div style="font-size:11px;color:#64748b;">Total</div>
              </div>
            </div>
            <div class="col-4">
              <div style="background:#dcfce7;border-radius:10px;padding:10px 6px;">
                <div style="font-size:20px;font-weight:700;color:#15803d;"><%= d.resolved %></div>
                <div style="font-size:11px;color:#15803d;">Resolved</div>
              </div>
            </div>
            <div class="col-4">
              <div style="background:#fee2e2;border-radius:10px;padding:10px 6px;">
                <div style="font-size:20px;font-weight:700;color:#b91c1c;"><%= d.slaBreached %></div>
                <div style="font-size:11px;color:#b91c1c;">SLA Breach</div>
              </div>
            </div>
          </div>
          <% if (d.total > 0) { %>
          <div class="mt-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:11px;color:#64748b;">
              <span>Resolution Rate</span>
              <span><%= Math.round((d.resolved + d.closed) / d.total * 100) %>%</span>
            </div>
            <div class="progress" style="height:6px;">
              <div class="progress-bar bg-success" style="width:<%= Math.round((d.resolved + d.closed) / d.total * 100) %>%"></div>
            </div>
          </div>
          <% } %>
          <div class="d-flex gap-3 mt-3" style="font-size:12px;color:#64748b;">
            <span><i class="bi bi-hourglass-split me-1 text-warning"></i>Open: <%= d.open %></span>
            <span><i class="bi bi-x-circle me-1 text-secondary"></i>Closed: <%= d.closed %></span>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
    <% if (data.length === 0) { %>
    <div class="col-12"><div class="card"><div class="card-body text-center py-5 text-muted"><i class="bi bi-person-x fs-2 d-block mb-2"></i>No engineers found</div></div></div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
