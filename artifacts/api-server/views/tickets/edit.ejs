<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-body p-4">
          <h5 class="mb-1 fw-700" style="color:#0f172a;"><i class="bi bi-pencil me-2 text-primary"></i>Edit Ticket</h5>
          <p class="text-muted mb-4" style="font-size:13px;"><%= ticket.ticketNumber %></p>

          <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form method="POST" action="/tickets/<%= ticket.id %>/edit">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Customer <span class="text-danger">*</span></label>
                <select name="customerId" class="form-select" required>
                  <% customers.forEach(c => { %>
                  <option value="<%= c.id %>" <%= ticket.customerId === c.id ? 'selected' : '' %>><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Category <span class="text-danger">*</span></label>
                <select name="categoryId" class="form-select" required>
                  <% categories.forEach(c => { %>
                  <option value="<%= c.id %>" <%= ticket.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Assign Engineer</label>
                <select name="assignedTo" class="form-select">
                  <option value="">— Unassigned —</option>
                  <% engineers.forEach(e => { %>
                  <option value="<%= e.id %>" <%= ticket.assignedTo === e.id ? 'selected' : '' %>><%= e.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Status</label>
                <select name="status" class="form-select">
                  <option value="Open" <%= ticket.status === 'Open' ? 'selected' : '' %>>Open</option>
                  <option value="In_Progress" <%= ticket.status === 'In_Progress' ? 'selected' : '' %>>In Progress</option>
                  <option value="Resolved" <%= ticket.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                  <option value="Closed" <%= ticket.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label fw-600" style="font-size:13px;">Remarks</label>
                <textarea name="remarks" class="form-control" rows="3"><%= ticket.remarks || '' %></textarea>
              </div>
              <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Update Ticket</button>
                <a href="/tickets/<%= ticket.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cancel</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
