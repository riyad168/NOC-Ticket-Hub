<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="row g-3">
    <div class="col-lg-8">
      <div class="card mb-3">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h5 class="fw-700 mb-1" style="color:#0f172a;"><%= ticket.ticketNumber %></h5>
              <span class="badge-status badge-<%= ticket.status.toLowerCase().replace('_','_') %> me-2"><%= ticket.status.replace('_',' ') %></span>
              <% if (ticket.slaBreached) { %><span class="badge-status badge-sla"><i class="bi bi-alarm me-1"></i>SLA Breach</span><% } else { %><span class="badge-status badge-within"><i class="bi bi-check2 me-1"></i>Within SLA</span><% } %>
            </div>
            <a href="/tickets/<%= ticket.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
          </div>
          <div class="row g-3">
            <div class="col-sm-6">
              <div class="p-3 rounded-3" style="background:#f8fafc;">
                <div style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Customer</div>
                <div style="font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;"><%= ticket.customer.name %></div>
                <% if (ticket.customer.phone) { %><div style="font-size:12px;color:#64748b;"><i class="bi bi-telephone me-1"></i><%= ticket.customer.phone %></div><% } %>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="p-3 rounded-3" style="background:#f8fafc;">
                <div style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Category</div>
                <div style="font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;"><%= ticket.category.name %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="p-3 rounded-3" style="background:#f8fafc;">
                <div style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Assigned Engineer</div>
                <div style="font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;"><%= ticket.assignedEngineer ? ticket.assignedEngineer.name : '— Unassigned —' %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="p-3 rounded-3" style="background:#f8fafc;">
                <div style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Created By</div>
                <div style="font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;"><%= ticket.createdBy.name %></div>
                <div style="font-size:12px;color:#64748b;"><%= new Date(ticket.createdAt).toLocaleString() %></div>
              </div>
            </div>
            <% if (ticket.remarks) { %>
            <div class="col-12">
              <div class="p-3 rounded-3" style="background:#fffbeb;border:1px solid #fde68a;">
                <div style="font-size:11px;color:#92400e;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Remarks</div>
                <div style="font-size:13.5px;color:#0f172a;margin-top:4px;"><%= ticket.remarks %></div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Ticket Logs -->
      <div class="card">
        <div class="card-body p-4">
          <h6 class="fw-600 mb-3" style="font-size:14px;"><i class="bi bi-clock-history me-2 text-primary"></i>Ticket History</h6>
          <% if (ticket.logs.length === 0) { %>
          <div class="text-center text-muted py-3">No activity yet</div>
          <% } %>
          <% ticket.logs.forEach(log => { %>
          <div class="d-flex gap-3 mb-3">
            <div style="width:34px;height:34px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <i class="bi bi-activity text-primary" style="font-size:14px;"></i>
            </div>
            <div style="flex:1;">
              <div class="d-flex justify-content-between">
                <span style="font-size:13px;font-weight:600;color:#0f172a;"><%= log.action %></span>
                <span style="font-size:11px;color:#94a3b8;"><%= new Date(log.createdAt).toLocaleString() %></span>
              </div>
              <div style="font-size:12px;color:#64748b;"><%= log.description %></div>
              <div style="font-size:11px;color:#94a3b8;">by <%= log.user.name %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card">
        <div class="card-body p-3">
          <h6 class="fw-600 mb-3" style="font-size:13px;">Quick Actions</h6>
          <div class="d-grid gap-2">
            <a href="/tickets/<%= ticket.id %>/edit" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit Ticket</a>
            <a href="/tickets" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
            <% if (user && (user.role === 'admin' || user.role === 'manager')) { %>
            <form method="POST" action="/tickets/<%= ticket.id %>/delete" onsubmit="return confirm('Delete this ticket?')">
              <button type="submit" class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-trash me-1"></i>Delete Ticket</button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
