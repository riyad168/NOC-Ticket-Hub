<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-body p-4">
          <h5 class="mb-4 fw-700" style="color:#0f172a;"><i class="bi bi-plus-circle me-2 text-primary"></i>Create New Ticket</h5>

          <% if (error) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= error %></div>
          <% } %>

          <form method="POST" action="/tickets/create">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Customer <span class="text-danger">*</span></label>
                <select name="customerId" class="form-select" required>
                  <option value="">— Select Customer —</option>
                  <% customers.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Category <span class="text-danger">*</span></label>
                <select name="categoryId" class="form-select" required>
                  <option value="">— Select Category —</option>
                  <% categories.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-600" style="font-size:13px;">Assign Engineer</label>
                <select name="assignedTo" class="form-select">
                  <option value="">— Unassigned —</option>
                  <% engineers.forEach(e => { %>
                  <option value="<%= e.id %>"><%= e.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label fw-600" style="font-size:13px;">Remarks</label>
                <textarea name="remarks" class="form-control" rows="3" placeholder="Describe the issue..."></textarea>
              </div>
              <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Create Ticket</button>
                <a href="/tickets" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cancel</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>
