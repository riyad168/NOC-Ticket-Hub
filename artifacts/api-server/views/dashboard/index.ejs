<%- include('../partials/head') %>
<div id="main">
<%- include('../partials/sidebar') %>
<%- include('../partials/topbar') %>
<div class="content-area">

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
      <div class="stat-card">
        <div class="d-flex align-items-center gap-3">
          <div class="icon" style="background:#dbeafe;color:#3b82f6;"><i class="bi bi-ticket-detailed"></i></div>
          <div>
            <div class="count"><%= stats.total.toLocaleString() %></div>
            <div class="label">Total Tickets</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl-3">
      <div class="stat-card">
        <div class="d-flex align-items-center gap-3">
          <div class="icon" style="background:#fef9c3;color:#ca8a04;"><i class="bi bi-hourglass-split"></i></div>
          <div>
            <div class="count"><%= stats.open.toLocaleString() %></div>
            <div class="label">Open Tickets</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl-3">
      <div class="stat-card">
        <div class="d-flex align-items-center gap-3">
          <div class="icon" style="background:#dcfce7;color:#16a34a;"><i class="bi bi-check-circle"></i></div>
          <div>
            <div class="count"><%= stats.resolved.toLocaleString() %></div>
            <div class="label">Resolved Tickets</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl-3">
      <div class="stat-card">
        <div class="d-flex align-items-center gap-3">
          <div class="icon" style="background:#fee2e2;color:#dc2626;"><i class="bi bi-exclamation-triangle"></i></div>
          <div>
            <div class="count"><%= stats.slaBreached.toLocaleString() %></div>
            <div class="label">SLA Breach Tickets</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <!-- Category Chart -->
    <div class="col-lg-5">
      <div class="card h-100">
        <div class="card-body">
          <h6 class="fw-600 mb-3" style="font-size:14px;">Tickets by Category</h6>
          <canvas id="categoryChart" height="220"></canvas>
        </div>
      </div>
    </div>
    <!-- Recent Activities -->
    <div class="col-lg-7">
      <div class="card h-100">
        <div class="card-body">
          <h6 class="fw-600 mb-3" style="font-size:14px;">Recent Activities</h6>
          <% if (recentLogs.length === 0) { %>
          <div class="text-center text-muted py-4"><i class="bi bi-clock-history fs-2 d-block mb-2"></i>No recent activities</div>
          <% } %>
          <% recentLogs.forEach(log => { %>
          <div class="d-flex align-items-start gap-3 mb-3">
            <div style="width:36px;height:36px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <i class="bi bi-activity text-primary" style="font-size:15px;"></i>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:600;color:#0f172a;"><%= log.action %></div>
              <div style="font-size:12px;color:#64748b;"><%= log.ticket.ticketNumber %> — <%= log.description %></div>
            </div>
            <div style="font-size:11px;color:#94a3b8;white-space:nowrap;">
              <%= new Date(log.createdAt).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'}) %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Tickets Table -->
  <div class="card">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="fw-600 mb-0" style="font-size:14px;">Latest Tickets</h6>
        <a href="/tickets" class="btn btn-sm btn-outline-primary" style="font-size:12px;">View All</a>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Ticket No</th>
              <th>Customer</th>
              <th>Category</th>
              <th>Status</th>
              <th>Engineer</th>
              <th>Start Time</th>
              <th>SLA</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentTickets.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No tickets found</td></tr>
            <% } %>
            <% recentTickets.forEach(ticket => { %>
            <tr>
              <td><span class="fw-600 text-primary"><%= ticket.ticketNumber %></span></td>
              <td><%= ticket.customer.name %></td>
              <td><span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size:11px;"><%= ticket.category.name %></span></td>
              <td>
                <% const s = ticket.status.toLowerCase().replace('_','_'); %>
                <span class="badge-status badge-<%= ticket.status.toLowerCase().replace(' ','_') %>"><%= ticket.status.replace('_',' ') %></span>
              </td>
              <td><%= ticket.assignedEngineer ? ticket.assignedEngineer.name : '<span class="text-muted">—</span>' %></td>
              <td style="font-size:12px;"><%= new Date(ticket.createdAt).toLocaleString('en-US', {month:'short',day:'2-digit',hour:'2-digit',minute:'2-digit'}) %></td>
              <td>
                <% if (ticket.slaBreached) { %>
                <span class="badge-status badge-sla">SLA Breach</span>
                <% } else { %>
                <span class="badge-status badge-within">Within SLA</span>
                <% } %>
              </td>
              <td>
                <a href="/tickets/<%= ticket.id %>" class="btn btn-sm btn-light" title="View"><i class="bi bi-eye"></i></a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</div>

<script>
const categoryData = <%- JSON.stringify(categoryData) %>;
if (categoryData.length > 0) {
  const ctx = document.getElementById('categoryChart').getContext('2d');
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: categoryData.map(d => d.name),
      datasets: [{ data: categoryData.map(d => d.count), backgroundColor: ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'], borderWidth: 0, hoverOffset: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'right', labels: { font: { size: 12 }, boxWidth: 12, padding: 12 } } },
      cutout: '70%'
    }
  });
}
</script>
